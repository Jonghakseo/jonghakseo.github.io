---
import { Image } from "astro:assets";

import PageLayout from "@/layouts/Base";
import meImg from "@/assets/me.jpeg";

const meta = {
	title: "About",
	description: "I'm Jonghak Seo, a product engineer focused on solving practical problems with AI and web technologies.",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-8">About</h1>
	<div class="grid grid-cols-3 gap-4">
		<Image
			src={meImg}
			alt="Jonghak Seo's photo"
			loading="eager"
			fetchpriority="high"
			style="border-radius: 16px"
		/>
		<div class="col-span-2 flex flex-col gap-2">
			<h2 class="title mb-2 text-xl">Introduction</h2>
			<p>Hi, I'm Jonghak Seo (Jong).</p>
			<p>
				I'm a product engineer interested in solving practical business problems with AI and web
				technologies.
			</p>
			<p>
				At Creatrip, I started as a frontend engineer and have gradually moved into leadership and
				system design work, collaborating with both technical and non-technical teams.
			</p>
			<p>
				I enjoy turning ambiguous workflow issues into concrete tools, then iterating with user
				feedback until they become part of daily work.
			</p>

			<h2 class="title mb-2 mt-6 text-xl">Experience</h2>
			<ul class="flex flex-col gap-4">
				<li>
					<p class="text-lg">
						<strong>Tech Lead</strong><small> at Creatrip (2025.05 ~ Present)</small>
					</p>
					<p class="mt-2 text-sm">
						Leading product and engineering initiatives around internal AI workflows, while supporting
						cross-functional adoption.
					</p>
				</li>
				<li>
					<p class="text-lg">
						<strong>Frontend Lead</strong><small> at Creatrip (2023.12 ~ 2025.05)</small>
					</p>
					<p class="mt-2 text-sm">
						Worked on frontend architecture, team productivity, performance, and developer experience
						improvements.
					</p>
				</li>
				<li>
					<p class="text-lg">
						<strong>Frontend Engineer</strong><small> at Creatrip (2021.12 ~ 2023.12)</small>
					</p>
					<p class="mt-2 text-sm">
						Built and improved user-facing reservation/purchase flows and internal admin experiences.
					</p>
				</li>
				<li>
					<p class="text-lg">
						<strong>Chrome Extension Consultant (Part-time)</strong><small> at Casemark AI (2023.05 ~ 2023.11)</small>
					</p>
					<p class="mt-2 text-sm">
						Contributed to browser-extension product development and technical direction.
					</p>
				</li>
				<li>
					<p class="text-lg">
						<strong>Frontend Engineer</strong><small> at Slogup (2019.09 ~ 2021.12)</small>
					</p>
					<p class="mt-2 text-sm">
						Developed web products and admin pages, including projects for enterprise clients.
					</p>
				</li>
			</ul>

			<h2 class="title mb-2 mt-6 text-xl">Selected Work</h2>
			<ul class="flex flex-col gap-4">
				<li>
					<strong>Internal AI Workspace (Creatrip)</strong>
					<p class="mt-2 text-sm">
						Designed and built an internal AI workspace used across teams, integrating daily tools like
						Slack, Gmail, Calendar, GA4, Jira, Notion, and more through natural language workflows.
					</p>
				</li>
				<li>
					<strong>AI Code Review Workflow</strong>
					<p class="mt-2 text-sm">
						Experimented with RAG-based review context and helped evolve team review workflows with AI
						support.
					</p>
				</li>
				<li>
					<strong>Product & Performance Engineering</strong>
					<p class="mt-2 text-sm">
						Worked on payment reliability and frontend performance improvements, including Core Web
						Vitals optimization and large-scale state/styling migrations.
					</p>
				</li>
			</ul>

			<h2 class="title mb-2 mt-6 text-xl">Open Source & Side Projects</h2>
			<ul class="flex flex-col gap-4">
				<li>
					<strong>
						<a
							href="https://github.com/Jonghakseo/chrome-extension-boilerplate-react-vite"
							target="_blank"
							rel="noopener noreferrer"
							>[chrome-extension-boilerplate-react-vite]</a
						>
					</strong>
					<p class="mt-2 text-sm">
						Boilerplate for Chrome Extension with React and Vite. Features custom HMR via wss.
						Maintained over several years and currently has 4,900+ stars on GitHub.
					</p>
				</li>
				<li>
					<strong>
						<a
							href="https://chromewebstore.google.com/detail/react-code-finder/bbidpgoneibefablhfcnaennjkfbflmk"
							target="_blank"
							rel="noopener noreferrer"
							>[React code finder chrome extension]</a
						>
					</strong>
					<p class="mt-2 text-sm">
						Chrome extension for finding React components in the browser. Has more than 650 users.
					</p>
				</li>
				<li>
					<strong>
						<a
							href="https://chromewebstore.google.com/detail/akgdgnhlglhelinkmnmiakgccdkghjbh"
							target="_blank"
							rel="noopener noreferrer"
							>[DragGPT chrome extension]</a
						>
					</strong>
					<p class="mt-2 text-sm">
						Chrome extension for using ChatGPT API via dragging. Has received more than 230 users
						and 50 stars.
					</p>
				</li>
			</ul>

			<h2 class="title mb-2 mt-6 text-xl">Links</h2>
			<ul class="flex flex-col gap-1 text-sm">
				<li>
					Email:
					<a href="mailto:unqocn@gmail.com" class="text-accent">unqocn@gmail.com</a>
				</li>
				<li>
					GitHub:
					<a href="https://github.com/Jonghakseo" target="_blank" rel="noopener noreferrer" class="text-accent"
						>github.com/Jonghakseo</a
					>
				</li>
				<li>
					LinkedIn:
					<a
						href="https://linkedin.com/in/jong-hak-seo-9142ba200"
						target="_blank"
						rel="noopener noreferrer"
						class="text-accent"
						>linkedin.com/in/jong-hak-seo-9142ba200</a
					>
				</li>
				<li>
					llms.txt:
					<a
						href="https://gist.github.com/Jonghakseo/56a9cdce67ea4fdfc787a84311ecc68a"
						target="_blank"
						rel="noopener noreferrer"
						class="text-accent"
						>jonghakseo/llms.txt</a
					>
				</li>
			</ul>
		</div>
	</div>
</PageLayout>
