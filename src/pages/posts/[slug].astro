---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection } from "astro:content";
import PostLayout from "@/layouts/BlogPost";
import Comments from "@/components/Comments";
import { getTranslationSlugs } from "@/utils";

export const getStaticPaths = (async () => {
	const blogEntries = await getCollection("post");
	const translationSlugs = getTranslationSlugs(blogEntries);

	// Only generate pages for main posts (exclude translation-only posts)
	const mainEntries = blogEntries.filter((e) => !translationSlugs.has(e.slug));

	return mainEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<PostLayout post={entry}>
	<Content />
	<Comments />
</PostLayout>
