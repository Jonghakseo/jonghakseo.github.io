---
import type { CollectionEntry } from "astro:content";

import BaseLayout from "./Base.astro";
import BlogHero from "@/components/blog/Hero";
import TOC from "@/components/blog/TOC";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const {
	data: { title, description, ogImage, publishDate, updatedDate, lang, translationSlug },
	slug,
} = post;
const socialImage = ogImage ?? `/og-image/${slug}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings } = await post.render();

const hasTranslation = !!translationSlug;
const targetLang = lang === "ko" ? "en" : "ko";
---

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ top: 0, behavior: "smooth" });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);
</script>

<script>
	function initLangToggle() {
		const toggleBtn = document.getElementById("lang-toggle-btn") as HTMLButtonElement | null;
		if (!toggleBtn) return;

		let translationCache: string | null = null;
		let isShowingTranslation = false;
		let originalContent: string | null = null;

		const targetLang = toggleBtn.dataset.targetLang!;
		const currentLang = toggleBtn.dataset.currentLang!;
		const translationSlug = toggleBtn.dataset.translationSlug!;

		const labelOriginal = targetLang === "ko" ? "🇰🇷 한국어로 보기" : "🇺🇸 Read in English";
		const labelTranslation = currentLang === "ko" ? "🇰🇷 한국어로 보기" : "🇺🇸 Read in English";

		// Check URL for initial lang param
		const urlParams = new URLSearchParams(window.location.search);
		const langParam = urlParams.get("lang");

		let translationQuality: string | null = null;

		async function loadTranslation(): Promise<string | null> {
			if (translationCache) return translationCache;

			toggleBtn!.textContent = "⏳ Loading...";
			toggleBtn!.disabled = true;

			try {
				const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
				const response = await fetch(`${basePath}/translations/${translationSlug}/`);
				if (!response.ok) throw new Error(`HTTP ${response.status}`);
				const rawHtml = await response.text();
				// DOMParser로 body content만 추출 (Astro boilerplate 제거)
				const doc = new DOMParser().parseFromString(rawHtml, "text/html");
				translationQuality = doc.body.dataset.translationQuality ?? null;
				translationCache = doc.body.innerHTML;
				return translationCache;
			} catch (e) {
				console.error("Failed to load translation:", e);
				toggleBtn!.textContent = labelOriginal;
				toggleBtn!.disabled = false;
				return null;
			}
		}

		function showQualityBanner(show: boolean) {
			const postContent = document.getElementById("post-content");
			if (!postContent) return;

			// Remove existing banner
			const existing = document.getElementById("translation-quality-banner");
			if (existing) existing.remove();

			if (show && translationQuality === "draft") {
				const banner = document.createElement("div");
				banner.id = "translation-quality-banner";
				banner.className =
					"mb-6 rounded-lg border border-yellow-400 bg-yellow-50 px-4 py-3 text-sm text-yellow-800 dark:border-yellow-600 dark:bg-yellow-900/20 dark:text-yellow-200";
				banner.innerHTML =
					'<span class="font-semibold">⚠️ AI Translation</span> — This translation was generated by AI. Technical terms or expressions may be inaccurate, and a review is planned.';
				if (targetLang === "ko") {
					banner.innerHTML =
						'<span class="font-semibold">⚠️ AI 번역</span> — 이 번역은 AI가 생성한 초벌 번역입니다. 기술 용어나 표현이 부정확할 수 있으며, 사후 검수가 진행될 예정입니다.';
				}
				postContent.insertBefore(banner, postContent.firstChild);
			}
		}

		async function showTranslation() {
			const postContent = document.getElementById("post-content");
			if (!postContent) return;

			if (!originalContent) {
				originalContent = postContent.innerHTML;
			}

			const html = await loadTranslation();
			if (!html) return;

			postContent.innerHTML = html;
			isShowingTranslation = true;
			toggleBtn!.textContent = labelTranslation;
			toggleBtn!.disabled = false;

			showQualityBanner(true);

			// Update URL without navigation
			const newUrl = new URL(window.location.href);
			newUrl.searchParams.set("lang", targetLang);
			window.history.replaceState({}, "", newUrl.toString());
		}

		function showOriginal() {
			const postContent = document.getElementById("post-content");
			if (!postContent || !originalContent) return;

			showQualityBanner(false);
			postContent.innerHTML = originalContent;
			isShowingTranslation = false;
			toggleBtn!.textContent = labelOriginal;

			// Update URL without navigation
			const newUrl = new URL(window.location.href);
			newUrl.searchParams.delete("lang");
			window.history.replaceState({}, "", newUrl.toString());
		}

		toggleBtn.addEventListener("click", async () => {
			if (!isShowingTranslation) {
				await showTranslation();
			} else {
				showOriginal();
			}
		});

		// Auto-load translation if ?lang= parameter is set
		if (langParam && langParam !== currentLang) {
			showTranslation();
		}
	}

	// Run on initial load
	initLangToggle();

	// Re-run on Astro view transitions
	document.addEventListener("astro:after-swap", initLangToggle);
</script>

<BaseLayout meta={{ title, description, articleDate, ogImage: socialImage }}>
	<div class="gap-x-10 lg:flex lg:items-start">
		{!!headings.length && <TOC headings={headings} />}
		<article class="flex-grow break-words" data-pagefind-body>
			<div id="blog-hero"><BlogHero content={post} /></div>
			{
				hasTranslation && (
					<div class="my-4 flex justify-end">
						<button
							id="lang-toggle-btn"
							data-target-lang={targetLang}
							data-current-lang={lang}
							data-translation-slug={translationSlug}
							class="rounded-lg border border-current px-3 py-1.5 text-sm font-medium transition-colors hover:bg-accent hover:text-bgColor"
						>
							{targetLang === "ko" ? "🇰🇷 한국어로 보기" : "🇺🇸 Read in English"}
						</button>
					</div>
				)
			}
			<div
				id="post-content"
				class="prose-m prose prose-cactus mt-12 max-w-3xl prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-accent prose-headings:before:content-['#'] prose-th:before:content-none"
			>
				<slot />
			</div>
		</article>
	</div>
	<button
		id="to-top-btn"
		class="z-90 fixed bottom-8 end-4 flex h-10 w-10 translate-y-28 items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all duration-300 hover:border-zinc-400 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 dark:bg-zinc-700 sm:end-8 sm:h-12 sm:w-12"
		aria-label="Back to Top"
		data-show="false"
		><svg
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
			focusable="false"
			fill="none"
			viewBox="0 0 24 24"
			stroke-width="2"
			stroke="currentColor"
			class="h-6 w-6"
		>
			<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"></path>
		</svg>
	</button>
</BaseLayout>
