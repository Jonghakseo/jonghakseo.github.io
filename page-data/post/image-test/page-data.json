its&amp;edge_flat=false&quot;/&gt;&lt;/a&gt;`;\n\n  return (\n    &lt;div&gt;\n      &lt;div&gt;\n        &lt;h1&gt;{frontmatter?.title}&lt;/h1&gt;\n        &lt;div dangerouslySetInnerHTML={{ __html: hitsCounter }} /&gt;\n        &lt;div dangerouslySetInnerHTML={{ __html: `${post?.html}` }} /&gt;\n      &lt;/div&gt;\n    &lt;/div&gt;\n  );\n}\n</code>\n        </deckgo-highlight-code>","frontmatter":{"title":"이미지"}}},"pageContext":{"slug":"/image-test/"}},
